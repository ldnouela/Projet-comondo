def amas_percole_verticalement_3D_r(amas, x,y,z):
    touche_haut = False
    touche_bas = False

    for i, j, k in amas:
        if i == 0:
            touche_haut = True
        if i == x - 1:
            touche_bas = True

    return touche_haut and touche_bas


def amas_percole_horizontalement_3D_r(amas, x,y,z):
    touche_gauche = False
    touche_droite = False

    for i, j, k in amas:
        if j == 0:
            touche_gauche = True
        if j == y - 1:
            touche_droite = True

    return touche_gauche and touche_droite


def amas_percole_frontback_3D_r(amas, x,y,z):
    touche_foward = False
    touche_back = False
    for i, j, k in amas:
        if k == 0:
            touche_foward = True
        if k == z - 1:
            touche_back = True
    return touche_foward and touche_back


def percole_3D_r(grille):
    x,y,z = grille.shape
    liste_amas = trouver_amas_3D_r(grille)

    for amas in liste_amas:
        if amas_percole_verticalement_3D_r(amas, x,y,z) or amas_percole_horizontalement_3D_r(amas,x,y,z) or amas_percole_frontback_3D_r(amas, x,y,z):
            return True

    return False



def proba_percolation_3D_r(x,y,z,p,nb_repetitions):
    compteur_percolation = 0

    for k in range(nb_repetitions):
        grille = generation_grille_3D_rectangle(x,y,z,p) #creations de grilles NxN à proba p aléatoires

        if percole_3D_r(grille): #voir si les grilles percoles si oui on augmente le compteur
            compteur_percolation += 1

    proba = compteur_percolation/nb_repetitions
    return proba



def estimer_pc(x,y,z, repetitions):
    valeurs_p = np.linspace(0.10, 0.75, 31)
    resultats = []

    for p in valeurs_p:
        proba = proba_percolation_3D_r(x,y,z, p, repetitions)
        resultats.append(proba)

    resultats = np.array(resultats)
    indice = np.argmin(abs(resultats - 0.5))
    pc_estime = valeurs_p[indice]

    return pc_estime, valeurs_p, resultats







def estimer_pc_3D_r(x, y, z, repetitions):

    valeurs_p = np.linspace(0.22, 0.35, 40)
