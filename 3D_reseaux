def exploration_amas_3D_r(grille,depart,visites):

    x,y,z = grille.shape #taille de la grille

    pile = [depart] #site de départ
    amas = [] #coordonnées des sites qui créent un amas avec le site depart

    visites.add(depart) #liste avec les sites déjà controlés pour ne pas les recontroler une seconde fois

    while pile:
        i,j,k = pile.pop()
        amas.append((i,j,k))

        for a,b,c in voisins_r(i,j,k,x,y,z): #controle des voisins du site observé
            if grille[a,b,c] and (a,b,c) not in visites: #test si le site voisin considéré et vide ou pas et si on l'a pas déjà controlé
                visites.add((a,b,c))
                pile.append((a,b,c))

    return amas

def trouver_amas_3D_r(grille):
    x,y,z = grille.shape
    visites = set() #creation d'un ensemble des sites déjà visités (ne contient pas de doublons, car set)
    liste_amas = [] #liste pour stocker les amas trouvés

    for i in range(x):
        for j in range(y): #pour chaque ligne i on parcourt toutes les colonnes j

            for k in range(z):
                if grille[i,j,k] and (i,j,k) not in visites: #vérifie si le site i,j est occupé ou non et s'il a déjà été visité ou non
                    amas = exploration_amas_3D_r(grille, (i,j,k),visites) #si c'est le cas, i,j et le début d'un nouvel amas et on utilise la fonction exploration_amas pour cartographier l'amas
                    liste_amas.append(amas) #on ajoute l'amas cartographié de départ i,j à la liste qui repère les amas
    return liste_amas


