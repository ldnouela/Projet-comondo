def voisins_r(i,j,k, x,y,z):
    candidats = [(i-1,j,k), (i+1,j,k), (i, j-1,k), (i,j+1,k),(i,j,k-1),(i,j,k+1)]
    voisins_valides = []

    for a, b, c in candidats:
        if 0 <= a < x and 0 <= b <  y  and 0<=c < z:
            voisins_valides.append((a,b,c))
    return voisins_valides


