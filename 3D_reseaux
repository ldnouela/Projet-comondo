def percole_3D_r_direction(grille, direction):
    x, y, z = grille.shape
    liste_amas = trouver_amas_3D_r(grille)

    for amas in liste_amas:

        if direction == "x":
            if amas_percole_verticalement_3D_r(amas, x, y, z):
                return True

        if direction == "y":
            if amas_percole_horizontalement_3D_r(amas, x, y, z):
                return True

        if direction == "z":
            if amas_percole_frontback_3D_r(amas, x, y, z):
                return True

    return False


def proba_percolation_3D_r_direction(x, y, z, p, repetitions, direction):
    compteur = 0

    for k in range(repetitions):
        grille = generation_grille_3D_rectangle(x, y, z, p)

        if percole_3D_r_direction(grille, direction):
            compteur += 1

    return compteur / repetitions

