# Paramètres du réseau carré 2D au seuil critique

# Seuil critique pour la percolation de sites sur un réseau carré 2D.
Pc_carre_2D = 0.592746

# Exposant critique théorique pour la distribution des tailles d'amas en 2D.
# Théoriquement : n(s) ~ s^(-tau), avec tau = 187/91.
Tau_theorique_2D = 187 / 91


# Génération du réseau

def generation_grille(N, p, seed=None):
    """
    Génère une grille carrée N x N pour la percolation de sites.

    Chaque site est occupé avec probabilité p.
    Un site occupé est représenté par True, un site vide par False.
    """
    rng = np.random.default_rng(seed)
    grille = rng.random((N, N)) < p
    return grille


# Voisinage sur le réseau carré

def voisins(i, j, N):
    """
    Renvoie les voisins valides du site (i, j).

    On utilise le voisinage à quatre directions :
    haut, bas, gauche, droite.
    Les voisins diagonaux ne sont pas pris en compte.
    """
    candidats = [
        (i - 1, j),  # haut
        (i + 1, j),  # bas
        (i, j - 1),  # gauche
        (i, j + 1),  # droite
    ]

    voisins_valides = []

    for a, b in candidats:
        if 0 <= a < N and 0 <= b < N:
            voisins_valides.append((a, b))

    return voisins_valides


# Recherche des amas

def exploration_amas(grille, depart, visites):
    """
    Explore l'amas connecté contenant le site depart.

    L'exploration se fait par parcours en profondeur.
    Le paramètre visites évite de traiter plusieurs fois le même site.
    """
    N = grille.shape[0]

    pile = [depart]
    amas = []

    visites.add(depart)

    while pile:
        i, j = pile.pop()
        amas.append((i, j))

        for a, b in voisins(i, j, N):
            if grille[a, b] and (a, b) not in visites:
                visites.add((a, b))
                pile.append((a, b))

    return amas


def trouver_amas(grille):
    """
    Trouve tous les amas occupés présents dans la grille.
    """
    N = grille.shape[0]
    visites = set()
    liste_amas = []

    for i in range(N):
        for j in range(N):
            if grille[i, j] and (i, j) not in visites:
                amas = exploration_amas(grille, (i, j), visites)
                liste_amas.append(amas)

    return liste_amas


# Collecte des tailles d'amas à p = pc

def collecter_tailles_amas(
    N,
    p=Pc_carre_2D,
    nb_configurations=300,
    enlever_plus_grand=True,
    seed=2026,
):
    """
    Simule plusieurs configurations indépendantes et collecte les tailles d'amas.

    Paramètres
    ----------
    N : int
        Taille du réseau carré.
    p : float
        Probabilité d'occupation des sites.
    nb_configurations : int
        Nombre de configurations simulées.
    enlever_plus_grand : bool
        Si True, retire le plus grand amas de chaque configuration.
        Cela limite les effets de taille finie près du seuil critique.
    seed : int
        Graine aléatoire pour rendre les résultats reproductibles.

    Retour
    ------
    np.ndarray
        Tableau contenant les tailles des amas collectés.
    """
    rng = np.random.default_rng(seed)
    toutes_les_tailles = []

    for k in range(nb_configurations):
        # Graine locale différente pour chaque configuration.
        local_seed = rng.integers(0, 2**32 - 1)

        # Génération d'une configuration au seuil critique.
        grille = generation_grille(N, p, seed=local_seed)

        # Détection de tous les amas de la configuration.
        liste_amas = trouver_amas(grille)

        # Conversion des amas en tailles.
        tailles = [len(amas) for amas in liste_amas]

        # Le plus grand amas est souvent fortement affecté par la taille finie.
        if enlever_plus_grand and len(tailles) > 0:
            tailles.remove(max(tailles))

        toutes_les_tailles.extend(tailles)

        # Affichage léger de l'avancement.
        if (k + 1) % max(1, nb_configurations // 10) == 0:
            print(f"Configurations traitées : {k + 1}/{nb_configurations}")

    return np.array(toutes_les_tailles, dtype=int)


# Distribution brute des tailles d'amas

def distribution_brute(tailles):
    """
    Calcule la distribution brute des tailles d'amas.

    Cette fonction compte combien d'amas ont une taille donnée s.
    """
    compteur = Counter(tailles)

    s_values = np.array(sorted(compteur.keys()))
    counts = np.array([compteur[s] for s in s_values])

    return s_values, counts


# Regroupement logarithmique

def log_binning(tailles, nb_bins=35):
    """
    Regroupe les tailles d'amas dans des intervalles logarithmiques.

    Le log-binning réduit le bruit dans la queue de distribution,
    ce qui rend la loi de puissance plus lisible sur un graphique log-log.
    """
    tailles = np.asarray(tailles)
    tailles = tailles[tailles > 0]

    if len(tailles) == 0:
        raise ValueError("Aucune taille d'amas disponible.")

    s_min = tailles.min()
    s_max = tailles.max()

    if s_min == s_max:
        raise ValueError("Toutes les tailles d'amas sont identiques.")

    # Bornes des classes, espacées régulièrement en échelle logarithmique.
    bins = np.logspace(np.log10(s_min), np.log10(s_max), nb_bins + 1)

    counts, edges = np.histogram(tailles, bins=bins)

    # Largeur de chaque classe.
    largeurs = edges[1:] - edges[:-1]

    # Centre géométrique de chaque classe, adapté à une échelle logarithmique.
    centres = np.sqrt(edges[:-1] * edges[1:])

    # On ignore les classes vides pour éviter log(0).
    masque = counts > 0

    centres = centres[masque]
    counts = counts[masque]
    largeurs = largeurs[masque]

    # Estimation de la densité de probabilité n(s).
    densite = counts / largeurs / len(tailles)

    return centres, densite


# Ajustement d'une loi de puissance

def ajuster_loi_puissance(centres, densite, s_min_fit=None, s_max_fit=None):
    """
    Ajuste une loi de puissance de la forme :

        n(s) = A s^(-tau)

    L'ajustement est fait par régression linéaire en échelle log-log.
    """
    centres = np.asarray(centres)
    densite = np.asarray(densite)

    # On ne garde que les valeurs strictement positives.
    masque = (centres > 0) & (densite > 0)

    # Restriction optionnelle de l'intervalle d'ajustement.
    if s_min_fit is not None:
        masque &= centres >= s_min_fit

    if s_max_fit is not None:
        masque &= centres <= s_max_fit

    if np.sum(masque) < 2:
        raise ValueError("Pas assez de points pour effectuer l'ajustement.")

    x = np.log(centres[masque])
    y = np.log(densite[masque])

    # Régression linéaire : log n(s) = log A - tau log s.
    slope, intercept = np.polyfit(x, y, 1)

    tau = -slope
    A = np.exp(intercept)

    return tau, A, masque


# Tracé de la distribution critique

def tracer_distribution_critique(
    N=150,
    p=Pc_carre_2D,
    nb_configurations=300,
    nb_bins=35,
    s_min_fit=80,
    s_max_fit=None,
    enlever_plus_grand=True,
    save_path="fig_distribution_critique.pdf",
    seed=2026,
):
    """
    Trace la distribution des tailles d'amas au voisinage du seuil critique.

    Le graphique obtenu permet de vérifier numériquement que :

        n(s) ~ s^(-tau)

    pour un réseau carré 2D à p proche de pc.
    """
    # Collecte des tailles d'amas sur plusieurs configurations indépendantes.
    tailles = collecter_tailles_amas(
        N=N,
        p=p,
        nb_configurations=nb_configurations,
        enlever_plus_grand=enlever_plus_grand,
        seed=seed,
    )

    # Construction de la distribution avec regroupement logarithmique.
    centres, densite = log_binning(tailles, nb_bins=nb_bins)

    # Ajustement numérique de l'exposant tau.
    tau, A, masque_fit = ajuster_loi_puissance(
        centres,
        densite,
        s_min_fit=s_min_fit,
        s_max_fit=s_max_fit,
    )

    # Courbe ajustée.
    x_fit = np.linspace(
        centres[masque_fit].min(),
        centres[masque_fit].max(),
        300,
    )
    y_fit = A * x_fit ** (-tau)

    # Droite de pente théorique, normalisée sur le premier point ajusté.
    x0 = centres[masque_fit][0]
    y0 = densite[masque_fit][0]
    y_theorie = y0 * (x_fit / x0) ** (-Tau_theorique_2D)

    # Tracé en échelle log-log.
    plt.figure(figsize=(7.5, 5.5))

    plt.loglog(
        centres,
        densite,
        "o",
        label="Données simulées avec log-binning",
    )

    plt.loglog(
        x_fit,
        y_fit,
        "-",
        label=rf"Ajustement numérique : $\tau \simeq {tau:.3f}$",
    )

    plt.loglog(
        x_fit,
        y_theorie,
        "--",
        color="black",
        label=rf"Pente théorique : $\tau=187/91\simeq {Tau_theorique_2D:.3f}$",
    )

    plt.xlabel(r"Taille de l'amas $s$")
    plt.ylabel(r"Distribution $n(s)$")
    plt.title(
        rf"Distribution critique des amas, "
        rf"$N={N}$, $p\simeq p_c$"
    )

    plt.legend()
    plt.grid(alpha=0.3, which="both")
    plt.tight_layout()
    plt.savefig(save_path, bbox_inches="tight")
    plt.show()

    # Résumé numérique de l'ajustement.
    print()
    print("===== Résultat de l'ajustement critique =====")
    print(f"N = {N}")
    print(f"p = {p}")
    print(f"Nombre de configurations = {nb_configurations}")
    print(f"Nombre total d'amas collectés = {len(tailles)}")
    print(
        f"Intervalle de fit : s >= {s_min_fit}"
        + ("" if s_max_fit is None else f", s <= {s_max_fit}")
    )
    print(f"tau numérique ≈ {tau:.4f}")
    print(f"tau théorique = 187/91 ≈ {Tau_theorique_2D:.4f}")
    print("============================================")
    print()

    # Données retournées pour une éventuelle réutilisation.
    resultats = {
        "tailles": tailles,
        "centres": centres,
        "densite": densite,
        "tau": tau,
        "A": A,
        "masque_fit": masque_fit,
        "N": N,
        "p": p,
        "nb_configurations": nb_configurations,
    }

    return resultats
