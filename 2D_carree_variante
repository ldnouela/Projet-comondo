def voisins_r_2d(i,j, x,y):
    candidats = [(i-1,j), (i+1,j), (i, j-1), (i,j+1)]
    voisins_valides = []

    for a, b in candidats:
        if 0 <= a < x and 0 <= b <  y :
            voisins_valides.append((a,b))
    return voisins_valides


