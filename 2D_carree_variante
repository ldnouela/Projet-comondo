def amas_percole_verticalement_2D_r(amas, x,y):
    touche_haut = False
    touche_bas = False

    for i, j in amas:
        if i == 0:
            touche_haut = True
        if i == x - 1:
            touche_bas = True

    return touche_haut and touche_bas


def amas_percole_horizontalement_2D_r(amas, x,y):
    touche_gauche = False
    touche_droite = False

    for i, j in amas:
        if j == 0:
            touche_gauche = True
        if j == y - 1:
            touche_droite = True

    return touche_gauche and touche_droite





def percole_2D_r(grille):
    x,y = grille.shape
    liste_amas = trouver_amas_2D_r(grille)

    for amas in liste_amas:
        if amas_percole_verticalement_2D_r(amas, x,y) or amas_percole_horizontalement_2D_r(amas,x,y):
            return True

    return False



def proba_percolation_2D_r(x,y,p,nb_repetitions):
    compteur_percolation = 0

    for k in range(nb_repetitions):
        grille = generation_grille_2D_rectangle(x,y,p) #creations de grilles NxN à proba p aléatoires

        if percole_2D_r(grille): #voir si les grilles percoles si oui on augmente le compteur
            compteur_percolation += 1

    proba = compteur_percolation/nb_repetitions
    return proba



def estimer_pc(x,y, repetitions):
    valeurs_p = np.linspace(0.10, 0.75, 31)
    resultats = []

    for p in valeurs_p:
        proba = proba_percolation_2D_r(x,y, p, repetitions)
        resultats.append(proba)

    resultats = np.array(resultats)
    indice = np.argmin(abs(resultats - 0.5))
    pc_estime = valeurs_p[indice]

    return pc_estime, valeurs_p, resultats




def estimer_pc_2D_r(x, y, repetitions):

    valeurs_p = np.linspace(0.1, 0.7, 70)
    resultats = []

    for p in valeurs_p:

        proba = proba_percolation_2D_r(x, y, p, repetitions)

        resultats.append(proba)

    resultats = np.array(resultats)

    indice = np.argmin(abs(resultats - 0.5))

    pc_estime = valeurs_p[indice]

    return pc_estime, valeurs_p, resultats


repetitions = 200
valeurs_p = np.linspace(0.5, 0.7, 60)
tailles = [
